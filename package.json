{
  "name": "stroid",
  "version": "0.1.4",
  "description": "Deterministic state engine for React and JavaScript with SSR-safe isolation, multi-store coordination, and decision-driven state workflows.",
  "keywords": [
    "state-management",
    "state",
    "store",
    "react",
    "hooks",
    "typescript",
    "async",
    "cache",
    "persistence",
    "sync",
    "broadcastchannel",
    "devtools",
    "ssr",
    "tree-shakeable"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./psr": {
      "types": "./dist/psr.d.ts",
      "import": "./dist/psr.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js"
    },
    "./runtime-tools": {
      "types": "./dist/runtime-tools.d.ts",
      "import": "./dist/runtime-tools.js"
    },
    "./runtime-admin": {
      "types": "./dist/runtime-admin.d.ts",
      "import": "./dist/runtime-admin.js"
    },
    "./selectors": {
      "types": "./dist/selectors.d.ts",
      "import": "./dist/selectors.js"
    },
    "./computed": {
      "types": "./dist/computed.d.ts",
      "import": "./dist/computed.js"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "import": "./dist/helpers.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server/portable": {
      "types": "./dist/server/portable.d.ts",
      "import": "./dist/server/portable.js"
    },
    "./async": {
      "types": "./dist/async.d.ts",
      "import": "./dist/async.js"
    },
    "./feature": {
      "types": "./dist/feature.d.ts",
      "import": "./dist/feature.js"
    },
    "./install": {
      "types": "./dist/install.d.ts",
      "import": "./dist/install.js"
    },
    "./persist": {
      "types": "./dist/persist.d.ts",
      "import": "./dist/persist.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "import": "./dist/sync.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "dist/**/*.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "tag": "beta"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Himesh-Bhattarai/stroid.git"
  },
  "bugs": {
    "url": "https://github.com/Himesh-Bhattarai/stroid/issues"
  },
  "homepage": "https://github.com/Himesh-Bhattarai/stroid#readme",
  "stroid": {
    "treeShakeable": true,
    "recommendedEntrypoints": [
      "./core",
      "./query",
      "./runtime-tools",
      "./persist",
      "./sync",
      "./devtools",
      "./async",
      "./react"
    ]
  },
  "scripts": {
    "test": "node scripts/run-node-tests.mjs main",
    "test:coverage": "c8 node scripts/run-node-tests.mjs main",
    "test:performance": "node scripts/run-node-tests.mjs performance",
    "test:heavy": "npm run test:performance",
    "test:package": "node scripts/run-node-tests.mjs package",
    "check:react-types": "node scripts/check-react-types.mjs",
    "check:publint": "node scripts/run-publint.mjs",
    "check:attw": "node scripts/run-attw.mjs",
    "docs:api": "api-extractor run --local",
    "test:dts": "tsc -p tsconfig.dtscheck.json --noEmit",
    "test:types": "npm run build && npm run check:publint && npm run check:attw && npm run test:package && npm run check:react-types && npm run docs:api && npm run test:dts && tsc -p tsconfig.typetests.json",
    "typecheck": "tsc -p tsconfig.types.json",
    "typecheck:layers": "tsc -b tsconfig.layers.json",
    "build": "tsup && node scripts/normalize-dts.mjs",
    "benchmark:compare": "node --expose-gc --import tsx scripts/compare-state-libraries.ts",
    "benchmark:core-small": "node --expose-gc --import tsx scripts/core-small-benchmark.ts",
    "benchmark:subscriber": "node --expose-gc --import tsx scripts/subscriber-benchmark.ts",
    "benchmark:subscriber:concurrent": "node --expose-gc --import tsx scripts/subscriber-concurrent-benchmark.ts",
    "benchmark:selector": "node --expose-gc --import tsx scripts/selector-benchmark.ts",
    "benchmark:deep-update": "node --expose-gc --import tsx scripts/deep-update-benchmark.ts",
    "benchmark:lifecycle": "node --expose-gc --import tsx scripts/lifecycle-benchmark.ts",
    "benchmark:ssr-isolation": "node --expose-gc --import tsx scripts/ssr-isolation-benchmark.ts",
    "benchmark:ssr-warm": "node --expose-gc --import tsx scripts/ssr-warm-container-benchmark.ts",
    "benchmark:serverless-provider": "node --expose-gc --import tsx scripts/serverless-provider-certification.ts",
    "benchmark:next-server-actions": "node --expose-gc --import tsx scripts/next-server-actions-benchmark.ts",
    "benchmark:react-concurrency": "node --expose-gc --import tsx scripts/react-concurrency-benchmark.ts",
    "benchmark:websocket-stream": "node --expose-gc --import tsx scripts/websocket-hydration-stream-benchmark.ts",
    "benchmark:ssr-fair-compare": "node --expose-gc --import tsx scripts/ssr-fair-compare.ts",
    "benchmark:atomic-failure": "node --expose-gc --import tsx scripts/atomic-failure-benchmark.ts",
    "benchmark:race": "node --expose-gc --import tsx scripts/race-condition-benchmark.ts",
    "benchmark:hydration-divergence": "node --expose-gc --import tsx scripts/hydration-divergence-benchmark.ts",
    "benchmark:hydration-randomized": "node --expose-gc --import tsx scripts/hydration-randomized-benchmark.ts",
    "benchmark:hydration-large-payload": "node --expose-gc --import tsx scripts/hydration-large-payload-benchmark.ts",
    "benchmark:determinism": "node --expose-gc --import tsx scripts/determinism-replay-benchmark.ts",
    "benchmark:memory-leak": "node --expose-gc --import tsx scripts/memory-leak-benchmark.ts",
    "benchmark:governance": "node --expose-gc --import tsx scripts/governance-lifecycle-benchmark.ts",
    "benchmark:guarantees": "node --expose-gc --import tsx scripts/guarantee-benchmark-suite.ts",
    "test:stress": "vitest run --config vitest.config.ts",
    "test:stress:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:stress:fuzz": "vitest run --config vitest.config.ts tests/fuzz/stress-fuzz.test.tsx",
    "bench:stress": "node --expose-gc --import tsx scripts/core/stress-benchmark-suite.bench.ts",
    "bench:stress:check": "node --import tsx scripts/core/check-benchmark-regression.bench.ts",
    "bench:stress:ci": "npm run bench:stress && npm run bench:stress:check",
    "bench:stress:update-baseline": "node -e \"const fs=require('fs'); const path=require('path'); const dir=path.resolve('scripts/benchmark-results'); fs.mkdirSync(dir,{recursive:true}); fs.copyFileSync(path.join(dir,'latest.json'), path.join(dir,'baseline.json')); console.log('updated scripts/benchmark-results/baseline.json');\"",
    "test:all": "npm test && npm run test:types",
    "test:full": "npm run test:coverage && npm run test:types"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "lodash": "4.18.1",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.9"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@microsoft/api-extractor": "^7.57.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.2.46",
    "@vitest/coverage-v8": "^3.2.4",
    "c8": "^10.1.2",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "immer": "^11.1.4",
    "jotai": "^2.12.4",
    "jsdom": "^25.0.1",
    "publint": "^0.3.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redux": "^5.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "zustand": "^5.0.11"
  }
}
