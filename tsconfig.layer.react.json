{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./.tsbuild/types",
    "tsBuildInfoFile": "./.tsbuild/layer-react.tsbuildinfo"
  },
  "references": [
    { "path": "./tsconfig.layer.core.json" },
    { "path": "./tsconfig.layer.async.json" },
    { "path": "./tsconfig.layer.computed.json" }
  ],
  "include": [
    "src/react/**/*.ts",
    "src/react/**/*.tsx"
  ]
}
