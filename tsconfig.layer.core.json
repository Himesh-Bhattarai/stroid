{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./.tsbuild/layer-core.tsbuildinfo"
  },
  "references": [
    { "path": "./tsconfig.layer.base.json" }
  ],
  "include": [
    "src/store-*.ts",
    "src/store-lifecycle/**/*.ts",
    "src/notification/**/*.ts",
    "src/internals/**/*.ts",
    "src/devfreeze.ts",
    "src/runtime-admin.ts",
